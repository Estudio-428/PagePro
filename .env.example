# ============================================================
# Product Page Builder — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores
# NUNCA commite o .env.local
# ============================================================

# ---- Nuvemshop ----
# Obter em: https://partners.nuvemshop.com.br → Aplicativos → Credenciais
NUVEMSHOP_APP_ID=
NUVEMSHOP_CLIENT_SECRET=
NUVEMSHOP_REDIRECT_URI=https://SEU_DOMINIO_RAILWAY/api/auth/callback

# ---- Banco de dados (Neon) ----
# Obter em: https://console.neon.tech → Connection Details
# Formato: postgresql://user:pass@host/dbname?sslmode=require
DATABASE_URL=

# ---- Sessão (iron-session) ----
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# ---- Criptografia (AES-256) ----
# Gerar com: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
ENCRYPTION_KEY=

# ---- App ----
NEXT_PUBLIC_APP_URL=https://SEU_DOMINIO_RAILWAY
NODE_ENV=production
